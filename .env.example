# ==============================================================================
# LangChain Showcase - Environment Variables Template
# Copy this file to a new file named `.env` and fill in your actual API keys.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Google Gemini GenAI API Key
# Get a key here: https://aistudio.google.com/
# ------------------------------------------------------------------------------
GOOGLE_API_KEY=your-gemini-api-key-here

# ------------------------------------------------------------------------------
# 2. OpenAI API Key
# Get a key here: https://platform.openai.com/api-keys
# ------------------------------------------------------------------------------
OPENAI_API_KEY=your-openai-api-key-here

# ------------------------------------------------------------------------------
# 3. Groq Cloud API Key
# Get a key here: https://console.groq.com/keys
# ------------------------------------------------------------------------------
GROQ_API_KEY=your-groq-api-key-here
